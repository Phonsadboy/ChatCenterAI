# Railway Environment Variables
# คัดลอกไฟล์นี้เป็น .env และกรอกค่าที่ถูกต้อง

# Port (Railway จะตั้งให้อัตโนมัติ)
PORT=3000

# Legacy document-store runtime has been removed.
# Use PostgreSQL, Redis, and bucket storage only in normal deployments.

# Runtime mode
# CCAI_RUNTIME_MODE=admin-app
# CCAI_ENABLE_LEGACY_BACKGROUND_JOBS=false
# Runtime services (set per Railway service)
# admin-app -> CCAI_RUNTIME_MODE=admin-app
# public-ingest -> CCAI_RUNTIME_MODE=public-ingest
# worker-realtime -> CCAI_RUNTIME_MODE=worker-realtime
# worker-batch -> CCAI_RUNTIME_MODE=worker-batch
# migration-runner -> CCAI_RUNTIME_MODE=migration-runner

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key

# OpenRouter (optional)
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your.domain.com
# OPENROUTER_X_TITLE=ChatCenterAI

# Public base URL that Facebook can access
PUBLIC_BASE_URL=https://your.domain.com
# Public base URL for webhook callbacks (recommended: public-ingest service URL)
# CCAI_INGEST_PUBLIC_BASE_URL=https://public-ingest-production.up.railway.app
# Forward /webhook/* from admin-app to public-ingest when callback is still on admin domain
# CCAI_ADMIN_FORWARD_WEBHOOKS_TO_INGEST=true
# CCAI_WEBHOOK_FORWARD_TIMEOUT_MS=4000
# Meta Graph API version for Facebook / Instagram / WhatsApp
META_GRAPH_API_VERSION=v22.0

# Admin security (เปิดระบบล็อกอินเมื่อกำหนดรหัส)
ADMIN_MASTER_PASSCODE=your_master_passcode
ADMIN_SESSION_SECRET=replace_with_random_session_secret
# ADMIN_SESSION_TTL_SECONDS=43200
# ADMIN_SESSION_COOKIE_NAME=admin_session

# Redis / BullMQ
REDIS_URL=redis://default:password@your-redis-host:6379
# CCAI_USE_REDIS_INFRA=true
# CCAI_SESSION_STORE_REDIS=true
# Required for public-ingest / worker-realtime
# CCAI_QUEUE_BACKEND_REDIS=true
# Required for public-ingest
# CCAI_DEDUPE_STORE_REDIS=true
# Recommended on Railway:
# worker-realtime -> CCAI_WORKER_REALTIME_CONCURRENCY=8
# CCAI_WORKER_BATCH_CONCURRENCY=2
# CCAI_QUEUE_CONVERSATION_FLUSH_ATTEMPTS=8
# CCAI_QUEUE_CONVERSATION_FLUSH_BACKOFF_MS=250
# CCAI_QUEUE_CONVERSATION_LOCK_TTL_MS=120000
# CCAI_QUEUE_CONVERSATION_LOCK_WAIT_TIMEOUT_MS=10000
# CCAI_QUEUE_CONVERSATION_LOCK_POLL_MS=120
# CCAI_QUEUE_CONVERSATION_LOCK_RETRY_DELAY_MS=250
# CCAI_QUEUE_CONVERSATION_LOCK_RETRY_ATTEMPTS=20

# PostgreSQL
DATABASE_URL=postgresql://user:password@your-postgres-host:5432/chatcenter
# CCAI_POSTGRES_ENABLED=true
# CCAI_RUN_POSTGRES_MIGRATIONS_ON_BOOT=true
# Cache + query guard for chat user list (reduces DB spikes on admin polling)
# CCAI_CHAT_USER_SUMMARY_CACHE_MS=5000
# CCAI_CHAT_USER_SUMMARY_SCAN_LIMIT=5000
# Reuse recent chat history reads in hot paths (AI/admin) to reduce repeated Postgres scans
# CCAI_CHAT_HISTORY_CACHE_MS=15000
# CCAI_CHAT_LATEST_CONTEXT_CACHE_MS=15000
# Limit AI history reads to recent days so old partitions are excluded from hot queries
# CCAI_AI_HISTORY_LOOKBACK_DAYS=21
# Add only a few recent orders into AI context to preserve customer/order memory without long chat history
# CCAI_AI_ORDER_CONTEXT_LIMIT=3
# CCAI_AI_ORDER_CONTEXT_ITEM_LIMIT=4
# CCAI_ADMIN_CHAT_USERS_CACHE_MS=2500
# Recommended on Railway web:
# CCAI_ADMIN_CHAT_USERS_CACHE_MS=15000
# Recommended Railway pool sizing:
# web -> CCAI_PG_POOL_MAX=6
# public-ingest -> CCAI_PG_POOL_MAX=4
# worker-realtime -> CCAI_PG_POOL_MAX=6
# worker-batch -> CCAI_PG_POOL_MAX=4
# migration-runner -> CCAI_PG_POOL_MAX=2
# worker-batch -> CCAI_POSTGRES_MAINTENANCE_ENABLED=true
# worker-batch -> CCAI_POSTGRES_MAINTENANCE_INTERVAL_MS=3600000
# worker-batch -> CCAI_POSTGRES_PARTITION_MONTHS_AHEAD=2
# worker-batch -> CCAI_WEBHOOK_EVENT_RETENTION_DAYS=14
# worker-batch -> CCAI_WEBHOOK_IDEMPOTENCY_RETENTION_DAYS=7
# CCAI_POSTGRES_MAINTENANCE_DELETE_BATCH_SIZE=5000
# CCAI_PG_MIGRATION_LOCK_ID=7482301
# CCAI_PG_MIGRATION_LOCK_TIMEOUT_MS=120000
# CCAI_PG_MIGRATION_LOCK_POLL_MS=1000
# PARITY_SAMPLE_LIMIT=200

# Migration runner pipeline flags
# CCAI_MIGRATION_RUN_SQL_MIGRATIONS=true
# Historical data migration and parity scripts have been retired from runtime mainline.
# Auto-run data migration during deployment boot (default enabled)
# Set to false to disable
# CCAI_MIGRATION_AUTO_RUN_ON_DEPLOY=true
# CCAI_MIGRATION_AUTO_RUN_MODES=admin-app
# CCAI_MIGRATION_DEPLOY_LOCK_ID=7482302
# CCAI_MIGRATION_DEPLOY_ID=

# Storage Bucket (Railway Storage Bucket / S3-compatible)
STORAGE_BUCKET_NAME=chatcenter-assets
STORAGE_S3_ENDPOINT=https://your-bucket-endpoint
STORAGE_REGION=ap-southeast-1
STORAGE_ACCESS_KEY_ID=your_access_key
STORAGE_SECRET_ACCESS_KEY=your_secret_key
# STORAGE_FORCE_PATH_STYLE=true

# History image reuse in AI context
# Disable synchronous URL validation by default to keep reply latency stable
# CCAI_HISTORY_IMAGE_URL_CHECK_ENABLED=false
# CCAI_HISTORY_IMAGE_URL_CHECK_TIMEOUT_MS=1500
# CCAI_HISTORY_IMAGE_ACCESSIBLE_PER_MESSAGE_LIMIT=1

# Webhook ingest audit and dedupe
# public-ingest/web -> CCAI_WEBHOOK_DEDUPE_TTL_SECONDS=86400
# public-ingest/web -> CCAI_WEBHOOK_EVENT_AUDIT_MODE=fallback_only
# public-ingest/web -> CCAI_WEBHOOK_EVENT_STORE_RAW_PAYLOAD=false
# public-ingest/web -> CCAI_WEBHOOK_EVENT_PAYLOAD_MAX_BYTES=4096

# Profile refresh
# Reuse stored LINE profiles for up to 6 hours before refreshing
# CCAI_LINE_PROFILE_REFRESH_TTL_MS=21600000
# Background refresh cooldown to avoid refetching the same profile every message
# CCAI_PROFILE_REFRESH_BACKGROUND_COOLDOWN_MS=300000

# Telemetry — ส่ง heartbeat ไป Telegram (ปิดได้ด้วย TELEMETRY_ENABLED=false)
# TELEMETRY_ENABLED=true
# TELEMETRY_TELEGRAM_BOT_TOKEN=123456:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEMETRY_TELEGRAM_CHAT_ID=-1001234567890
