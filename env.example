# Railway Environment Variables
# คัดลอกไฟล์นี้เป็น .env และกรอกค่าที่ถูกต้อง

# Port (Railway จะตั้งให้อัตโนมัติ)
PORT=3000

# PostgreSQL + bucket runtime
CHAT_STORAGE_MODE=postgres
APP_DOCUMENT_MODE=postgres
SESSION_STORE_MODE=postgres
# CHAT_HOT_RETENTION_DAYS=60
# CHAT_HISTORY_LIMIT=200
# CHAT_ARCHIVE_EXPORT_ENABLED=true
# DATABASE_URL=postgresql://postgres:password@host:5432/railway
# DATABASE_SSL=false
# POSTGRES_MAX_POOL_SIZE=10
# POSTGRES_STATEMENT_TIMEOUT_MS=10000

# Legacy MongoDB connection string (migration/rollback only; not needed after cutover)
# MONGO_URI=mongodb://user:password@host:27017/chatbot
# MONGODB_URI=mongodb://user:password@host:27017/chatbot

# Railway Bucket / S3 compatible storage
# BUCKET_NAME=chatcenter-assets
# BUCKET_ENDPOINT=https://<bucket-endpoint>
# BUCKET_REGION=auto
# BUCKET_ACCESS_KEY_ID=your_access_key
# BUCKET_SECRET_ACCESS_KEY=your_secret_key
# BUCKET_FORCE_PATH_STYLE=true
# BUCKET_KEY_PREFIX=review

# Legacy database bootstrap retry tuning (optional)
# MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
# MONGO_CONNECT_TIMEOUT_MS=15000
# MONGO_SOCKET_TIMEOUT_MS=30000
# MONGO_MAX_POOL_SIZE=20
# MONGO_MIN_POOL_SIZE=0
# MONGO_BOOTSTRAP_RETRY_DELAY_MS=5000
# MONGO_BOOTSTRAP_MAX_RETRY_DELAY_MS=60000

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key

# OpenRouter (optional)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your.domain.com
# OPENROUTER_X_TITLE=ChatCenterAI

# Public base URL that Facebook can access
PUBLIC_BASE_URL=https://your.domain.com
# Meta Graph API version for Facebook / Instagram / WhatsApp
META_GRAPH_API_VERSION=v22.0

# Admin security (เปิดระบบล็อกอินเมื่อกำหนดรหัส)
ADMIN_MASTER_PASSCODE=your_master_passcode
ADMIN_SESSION_SECRET=replace_with_random_session_secret
# ADMIN_SESSION_TTL_SECONDS=43200
# ADMIN_SESSION_COOKIE_NAME=admin_session

# Telemetry — ส่ง heartbeat ไป Telegram (ปิดได้ด้วย TELEMETRY_ENABLED=false)
# TELEMETRY_ENABLED=true
# TELEMETRY_TELEGRAM_BOT_TOKEN=123456:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEMETRY_TELEGRAM_CHAT_ID=-1001234567890
