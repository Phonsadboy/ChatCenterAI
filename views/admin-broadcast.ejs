<!DOCTYPE html>
<html lang="th">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>บรอดแคสต์ข้อความถึงผู้ใช้</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <link href="/css/admin-broadcast.css" rel="stylesheet">
  <link href="/css/mobile-improvements.css" rel="stylesheet">
</head>

<body class="app-shell page-broadcast">
  <%- include('partials/admin-navbar', { activePage: 'broadcast' }) %>

  <div class="app-content">
    <% const lineCount=(lineBots && lineBots.length) || 0; const fbCount=(facebookBots && facebookBots.length) || 0;
      const igCount=(instagramBots && instagramBots.length) || 0; const waCount=(whatsappBots && whatsappBots.length) || 0;
      const totalBots=lineCount + fbCount + igCount + waCount; %>

    <div class="container-fluid p-0">

      <!-- Page Header -->
      <div class="bc-page-header">
        <div class="bc-page-header__left">
          <div class="bc-page-header__icon">
            <i class="fas fa-bullhorn"></i>
          </div>
          <div>
            <h1 class="bc-page-header__title">ส่งข้อความบรอดแคสต์</h1>
            <p class="bc-page-header__desc">เลือกกลุ่มเป้าหมายและช่องทางที่ต้องการ แล้วส่งข้อความถึงลูกค้าพร้อมกัน</p>
          </div>
        </div>
        <div class="bc-page-header__right">
          <div class="bc-platform-chips">
            <span class="bc-platform-chip">
              <i class="fas fa-robot"></i>
              บอทรวม <strong><%= totalBots %></strong>
            </span>
            <span class="bc-platform-chip bc-platform-chip--line">
              <i class="fab fa-line"></i> <strong><%= lineCount %></strong>
            </span>
            <span class="bc-platform-chip bc-platform-chip--fb">
              <i class="fab fa-facebook"></i> <strong><%= fbCount %></strong>
            </span>
            <% if (igCount > 0) { %>
            <span class="bc-platform-chip bc-platform-chip--ig">
              <i class="fab fa-instagram"></i> <strong><%= igCount %></strong>
            </span>
            <% } %>
            <% if (waCount > 0) { %>
            <span class="bc-platform-chip bc-platform-chip--wa">
              <i class="fab fa-whatsapp"></i> <strong><%= waCount %></strong>
            </span>
            <% } %>
          </div>
          <a href="/admin/dashboard" class="btn btn-sm btn-ghost-base">
            <i class="fas fa-arrow-left me-1"></i> กลับแดชบอร์ด
          </a>
        </div>
      </div>

      <% if (typeof error !== 'undefined') { %>
      <div class="alert alert-danger alert-dismissible fade show mb-3">
        <i class="fas fa-exclamation-circle me-2"></i><%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
      <% } %>
      <% if (typeof success !== 'undefined') { %>
      <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="fas fa-check-circle me-2"></i><%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
      <% } %>

      <!-- Main Layout -->
      <div class="bc-layout">
        <!-- Left: Form -->
        <div class="bc-form-col">
          <form method="POST" action="/admin/broadcast" id="broadcastForm" novalidate>

            <!-- Step 1: Messages -->
            <div class="bc-section">
              <div class="bc-section__header">
                <span class="bc-step-num">1</span>
                <div>
                  <div class="bc-section__title">ข้อความที่ต้องการส่ง</div>
                  <div class="bc-section__subtitle">ส่งได้สูงสุด 5 บอลลูน (ข้อความและรูปภาพ)</div>
                </div>
              </div>
              <div class="bc-section__body">
                <div id="messageList" class="bc-message-list">
                  <div class="bc-message-empty">
                    <i class="fas fa-comment-dots"></i>
                    <span>ยังไม่มีข้อความ กดปุ่มด้านล่างเพื่อเพิ่ม</span>
                  </div>
                </div>
                <div class="bc-add-msg-actions">
                  <button type="button" class="bc-add-btn bc-add-btn--text" id="addTextBtn">
                    <i class="fas fa-comment-alt"></i> เพิ่มข้อความ
                  </button>
                  <button type="button" class="bc-add-btn bc-add-btn--image" id="addImageBtn">
                    <i class="fas fa-image"></i> เพิ่มรูปภาพ
                  </button>
                </div>
                <input type="hidden" name="messages" id="messagesInput">
              </div>
            </div>

            <!-- Step 2: Audience & Filters -->
            <div class="bc-section">
              <div class="bc-section__header">
                <span class="bc-step-num">2</span>
                <div>
                  <div class="bc-section__title">กลุ่มเป้าหมาย</div>
                  <div class="bc-section__subtitle">เลือกกลุ่มผู้ใช้ที่ต้องการส่งถึง</div>
                </div>
              </div>
              <div class="bc-section__body">

                <!-- Audience Type -->
                <div class="bc-audience-grid">
                  <button type="button" class="bc-audience-card active" data-value="all" aria-pressed="true">
                    <input class="form-check-input" type="radio" name="audience" id="audAll" value="all" checked>
                    <div class="bc-audience-card__icon">
                      <i class="fas fa-users"></i>
                    </div>
                    <div class="bc-audience-card__text">
                      <div class="bc-audience-card__title">ผู้ใช้ทุกคน</div>
                      <div class="bc-audience-card__desc">ส่งถึงผู้ใช้ทั้งหมด</div>
                    </div>
                  </button>
                  <button type="button" class="bc-audience-card" data-value="tagged" aria-pressed="false">
                    <input class="form-check-input" type="radio" name="audience" id="audTagged" value="tagged">
                    <div class="bc-audience-card__icon bc-audience-card__icon--warning">
                      <i class="fas fa-star"></i>
                    </div>
                    <div class="bc-audience-card__text">
                      <div class="bc-audience-card__title">กลุ่มติดตาม</div>
                      <div class="bc-audience-card__desc">ผู้ใช้ที่ติดแท็ก follow_up</div>
                    </div>
                  </button>
                  <button type="button" class="bc-audience-card" data-value="untagged" aria-pressed="false">
                    <input class="form-check-input" type="radio" name="audience" id="audUntagged" value="untagged">
                    <div class="bc-audience-card__icon bc-audience-card__icon--success">
                      <i class="fas fa-user-plus"></i>
                    </div>
                    <div class="bc-audience-card__text">
                      <div class="bc-audience-card__title">ผู้ใช้ทั่วไป</div>
                      <div class="bc-audience-card__desc">ยกเว้นผู้ใช้แท็ก follow_up</div>
                    </div>
                  </button>
                </div>

                <!-- Order Filter -->
                <div class="bc-filter-group">
                  <label class="bc-filter-label">
                    <i class="fas fa-shopping-bag me-1 text-muted"></i> สถานะออเดอร์
                  </label>
                  <div class="bc-pill-tabs">
                    <label class="bc-pill-tab">
                      <input type="radio" name="orderFilter" value="all" checked>
                      <span>ทั้งหมด</span>
                    </label>
                    <label class="bc-pill-tab">
                      <input type="radio" name="orderFilter" value="with_order">
                      <span><i class="fas fa-check-circle me-1 text-success"></i>มีออเดอร์</span>
                    </label>
                    <label class="bc-pill-tab">
                      <input type="radio" name="orderFilter" value="without_order">
                      <span><i class="fas fa-times-circle me-1 text-muted"></i>ไม่มีออเดอร์</span>
                    </label>
                  </div>
                </div>

                <!-- Date Filter -->
                <div class="bc-filter-group">
                  <label class="bc-filter-label">
                    <i class="fas fa-calendar-alt me-1 text-muted"></i> ช่วงวันที่ทักเข้ามา
                  </label>
                  <div class="bc-pill-tabs">
                    <label class="bc-pill-tab">
                      <input type="radio" name="dateFilterMode" id="dateModeAll" value="all" checked>
                      <span>ทั้งหมด</span>
                    </label>
                    <label class="bc-pill-tab">
                      <input type="radio" name="dateFilterMode" id="dateModeToday" value="today">
                      <span>วันนี้</span>
                    </label>
                    <label class="bc-pill-tab">
                      <input type="radio" name="dateFilterMode" id="dateModeCustom" value="custom">
                      <span>กำหนดเอง</span>
                    </label>
                  </div>
                  <div id="dateRangeFields" class="bc-date-range" style="display:none;">
                    <div class="bc-date-range__field">
                      <label class="bc-date-range__label">วันที่เริ่ม</label>
                      <input type="date" id="dateStartInput" class="form-control form-control-sm">
                    </div>
                    <div class="bc-date-range__sep"><i class="fas fa-arrow-right text-muted"></i></div>
                    <div class="bc-date-range__field">
                      <label class="bc-date-range__label">วันที่สิ้นสุด</label>
                      <input type="date" id="dateEndInput" class="form-control form-control-sm">
                    </div>
                  </div>
                </div>

                <!-- Audience Stats -->
                <div id="audienceStats" class="bc-audience-stat" style="display: none;">
                  <i class="fas fa-users me-1"></i>
                  จะส่งถึงประมาณ <strong id="audienceTotal" class="text-primary">--</strong> คน
                  <span class="bc-audience-stat__breakdown">
                    (LINE: <span id="audienceLine">--</span>,
                    Facebook: <span id="audienceFb">--</span>,
                    Instagram: <span id="audienceIg">--</span>,
                    WhatsApp: <span id="audienceWa">--</span>)
                  </span>
                </div>
                <div id="timeEstimate" class="bc-time-estimate" style="display: none;">
                  <i class="fas fa-clock me-1"></i>
                  <span id="timeEstimateText"></span>
                </div>

              </div>
            </div>

            <!-- Step 3: Channels -->
            <div class="bc-section">
              <div class="bc-section__header">
                <span class="bc-step-num">3</span>
                <div>
                  <div class="bc-section__title">เลือกช่องทาง</div>
                  <div class="bc-section__subtitle">เลือกได้หลายช่องทางพร้อมกัน</div>
                </div>
              </div>
              <div class="bc-section__body">
                <% if (totalBots > 0) { %>
                <div class="bc-channels-wrap">
                  <% if (lineBots && lineBots.length) { %>
                  <div class="bc-channel-group">
                    <div class="bc-channel-group__header bc-channel-group__header--line">
                      <i class="fab fa-line"></i> LINE Bots
                    </div>
                    <div class="bc-channel-group__list">
                      <% lineBots.forEach(bot => { %>
                      <label class="bc-channel-item" for="line-<%= bot._id %>">
                        <input class="bc-channel-item__check" type="checkbox" name="channels"
                          id="line-<%= bot._id %>" value="line:<%= bot._id %>">
                        <div class="bc-channel-item__icon bc-channel-item__icon--line">
                          <i class="fab fa-line"></i>
                        </div>
                        <div class="bc-channel-item__info">
                          <span class="bc-channel-item__name"><%= bot.name %></span>
                          <% if (bot.channelId) { %>
                          <span class="bc-channel-item__id"><%= bot.channelId %></span>
                          <% } %>
                        </div>
                        <div class="bc-channel-item__check-icon"><i class="fas fa-check"></i></div>
                      </label>
                      <% }) %>
                    </div>
                  </div>
                  <% } %>

                  <% if (facebookBots && facebookBots.length) { %>
                  <div class="bc-channel-group">
                    <div class="bc-channel-group__header bc-channel-group__header--fb">
                      <i class="fab fa-facebook"></i> Facebook Pages
                    </div>
                    <div class="bc-channel-group__list">
                      <% facebookBots.forEach(bot => { %>
                      <label class="bc-channel-item" for="fb-<%= bot._id %>">
                        <input class="bc-channel-item__check" type="checkbox" name="channels"
                          id="fb-<%= bot._id %>" value="facebook:<%= bot._id %>">
                        <div class="bc-channel-item__icon bc-channel-item__icon--fb">
                          <i class="fab fa-facebook"></i>
                        </div>
                        <div class="bc-channel-item__info">
                          <span class="bc-channel-item__name"><%= bot.name %></span>
                          <% if (bot.pageId) { %>
                          <span class="bc-channel-item__id"><%= bot.pageId %></span>
                          <% } %>
                        </div>
                        <div class="bc-channel-item__check-icon"><i class="fas fa-check"></i></div>
                      </label>
                      <% }) %>
                    </div>
                  </div>
                  <% } %>

                  <% if (instagramBots && instagramBots.length) { %>
                  <div class="bc-channel-group">
                    <div class="bc-channel-group__header bc-channel-group__header--ig">
                      <i class="fab fa-instagram"></i> Instagram Accounts
                    </div>
                    <div class="bc-channel-group__list">
                      <% instagramBots.forEach(bot => { %>
                      <label class="bc-channel-item" for="ig-<%= bot._id %>">
                        <input class="bc-channel-item__check" type="checkbox" name="channels"
                          id="ig-<%= bot._id %>" value="instagram:<%= bot._id %>">
                        <div class="bc-channel-item__icon bc-channel-item__icon--ig">
                          <i class="fab fa-instagram"></i>
                        </div>
                        <div class="bc-channel-item__info">
                          <span class="bc-channel-item__name"><%= bot.name || bot.username %></span>
                        </div>
                        <div class="bc-channel-item__check-icon"><i class="fas fa-check"></i></div>
                      </label>
                      <% }) %>
                    </div>
                  </div>
                  <% } %>

                  <% if (whatsappBots && whatsappBots.length) { %>
                  <div class="bc-channel-group">
                    <div class="bc-channel-group__header bc-channel-group__header--wa">
                      <i class="fab fa-whatsapp"></i> WhatsApp Bots
                    </div>
                    <div class="bc-channel-group__list">
                      <% whatsappBots.forEach(bot => { %>
                      <label class="bc-channel-item" for="wa-<%= bot._id %>">
                        <input class="bc-channel-item__check" type="checkbox" name="channels"
                          id="wa-<%= bot._id %>" value="whatsapp:<%= bot._id %>">
                        <div class="bc-channel-item__icon bc-channel-item__icon--wa">
                          <i class="fab fa-whatsapp"></i>
                        </div>
                        <div class="bc-channel-item__info">
                          <span class="bc-channel-item__name"><%= bot.name %></span>
                          <% if (bot.phoneNumber) { %>
                          <span class="bc-channel-item__id"><%= bot.phoneNumber %></span>
                          <% } %>
                        </div>
                        <div class="bc-channel-item__check-icon"><i class="fas fa-check"></i></div>
                      </label>
                      <% }) %>
                    </div>
                  </div>
                  <% } %>
                </div>
                <% } else { %>
                <div class="app-empty">
                  <div class="app-empty__icon"><i class="fas fa-robot"></i></div>
                  <div class="app-empty__title">ยังไม่มีบอทที่เพิ่มไว้</div>
                  <div class="app-empty__desc">ไปที่หน้า "ตั้งค่า" เพื่อเพิ่ม LINE/Facebook Bot ก่อน</div>
                  <a href="/admin/settings2" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus me-1"></i> เพิ่มบอทใหม่
                  </a>
                </div>
                <% } %>
              </div>
            </div>

            <!-- Step 4: Rate Limiting -->
            <div class="bc-section bc-section--subtle">
              <div class="bc-section__header">
                <span class="bc-step-num bc-step-num--muted"><i class="fas fa-sliders-h"></i></span>
                <div>
                  <div class="bc-section__title">ตั้งค่าความเร็ว</div>
                  <div class="bc-section__subtitle">Rate Limiting — ปรับตามความเหมาะสมของ API</div>
                </div>
              </div>
              <div class="bc-section__body">
                <div class="bc-rate-grid">
                  <div class="bc-rate-field">
                    <label class="bc-rate-label">ส่งครั้งละ (คน)</label>
                    <input type="number" name="settings_batchSize" class="form-control form-control-sm" value="20" min="1" max="100">
                  </div>
                  <div class="bc-rate-field">
                    <label class="bc-rate-label">เว้นช่วง (วินาที)</label>
                    <input type="number" name="settings_batchDelay" class="form-control form-control-sm" value="30" min="5" max="300">
                  </div>
                  <div class="bc-rate-field">
                    <label class="bc-rate-label">หน่วงเวลา/คน (วินาที)</label>
                    <input type="number" name="settings_messageDelay" class="form-control form-control-sm" value="1" min="0.1" max="5" step="0.1">
                  </div>
                </div>
              </div>
            </div>

            <!-- Submit Bar -->
            <div class="bc-submit-bar">
              <a href="/admin/dashboard" class="btn btn-ghost-base">
                <i class="fas fa-arrow-left me-1"></i> กลับ
              </a>
              <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-primary btn-sm" id="previewBtnInline">
                  <i class="fas fa-eye me-1"></i> ดูตัวอย่าง
                </button>
                <button type="submit" class="btn btn-primary" id="submitBroadcastBtn">
                  <i class="fas fa-paper-plane me-1"></i> ส่งข้อความ
                </button>
              </div>
            </div>

          </form>
        </div>

        <!-- Right: Preview Panel -->
        <div class="bc-preview-col">
          <div class="bc-preview-panel" id="broadcastPreview">
            <div class="bc-preview-panel__header">
              <div class="bc-preview-panel__title">
                <i class="fas fa-eye me-1"></i> ตัวอย่างข้อความ
              </div>
              <small class="bc-preview-panel__status" id="previewStatus">ยังไม่มีข้อความ</small>
            </div>

            <!-- Chat-style preview -->
            <div class="bc-preview-chat">
              <div class="bc-preview-messages" id="previewMessage">
                <div class="bc-preview-placeholder">
                  <i class="fas fa-comment-dots"></i>
                  <span>พิมพ์ข้อความเพื่อดูตัวอย่าง</span>
                </div>
              </div>
            </div>

            <!-- Preview Meta -->
            <div class="bc-preview-meta">
              <div class="bc-preview-meta__row">
                <span class="bc-preview-meta__icon"><i class="fas fa-users"></i></span>
                <span class="bc-preview-meta__label">ส่งถึง:</span>
                <span class="bc-preview-meta__value" id="previewAudienceLabel">ผู้ใช้ทุกคน</span>
              </div>
              <div class="bc-preview-meta__row">
                <span class="bc-preview-meta__icon"><i class="fas fa-share-alt"></i></span>
                <span class="bc-preview-meta__label">ช่องทาง:</span>
                <span class="bc-preview-meta__value" id="previewChannelsLabel">ยังไม่เลือก</span>
              </div>
            </div>

            <div class="bc-preview-note">
              <i class="fas fa-info-circle me-1"></i> ตัวอย่างข้อความแบบรวมทุกช่องทาง
            </div>
          </div>

          <!-- Audience Count Card -->
          <div class="bc-audience-card-panel" id="audienceStatsPanel" style="display: none;">
            <div class="bc-audience-card-panel__title">
              <i class="fas fa-chart-bar me-1"></i> จำนวนผู้รับโดยประมาณ
            </div>
            <div class="bc-audience-stats-grid" id="audienceStatsGrid">
              <!-- filled by JS -->
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="broadcastToastContainer" class="app-toast-container"></div>

  <!-- Progress Modal -->
  <div class="modal fade" id="progressModal" data-bs-backdrop="static" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title">
            <i class="fas fa-paper-plane text-primary me-2"></i>กำลังส่งบรอดแคสต์
          </h5>
        </div>
        <div class="modal-body pt-2">
          <!-- Overall Progress -->
          <div class="broadcast-progress-overall mb-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <div class="broadcast-time-info">
                <span class="broadcast-time-badge" id="elapsedTimeBadge">
                  <i class="fas fa-stopwatch me-1"></i><span id="elapsedTime">00:00</span>
                </span>
                <span class="broadcast-time-badge broadcast-time-badge--remaining" id="remainingTimeBadge">
                  <i class="fas fa-hourglass-half me-1"></i>เหลือ <span id="remainingTime">--</span>
                </span>
              </div>
              <div class="text-muted small fw-semibold">
                <span id="sentCount">0</span> / <span id="totalCount">0</span> คน
              </div>
            </div>
            <div class="progress mb-1" style="height: 22px;">
              <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%"></div>
            </div>
            <div class="d-flex justify-content-between small text-muted mt-1">
              <span><i class="fas fa-check-circle text-success me-1"></i>สำเร็จ <span id="successCount">0</span></span>
              <span><i class="fas fa-times-circle text-danger me-1"></i>ล้มเหลว <span id="failedCount">0</span></span>
            </div>
          </div>
          <!-- Per-Channel Cards -->
          <div id="channelProgressList" class="broadcast-channel-list"></div>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-outline-danger btn-sm" id="cancelBroadcastBtn">
            <i class="fas fa-stop-circle me-1"></i>ยกเลิกการส่ง
          </button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/admin-broadcast.js"></script>
</body>

</html>
