<!DOCTYPE html>
<html lang="th">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>ตั้งค่าติดตามลูกค้า | จัดการ AI</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Mali:wght@200;300;400;500;600;700&family=Inter:wght@400;500;600;700&display=swap"
    rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <link href="/css/admin-followup.css" rel="stylesheet">
</head>

<body class="app-shell">
  <%- include('partials/admin-navbar', { activePage: 'followup' }) %>

  <div class="app-content">
    <div class="followup-layout">
      <!-- Left Sidebar -->
      <aside class="followup-sidebar">
        <div class="followup-sidebar-header">
          <h5 class="followup-sidebar-title"><i class="fas fa-sliders-h me-2"></i>ตั้งค่าติดตาม</h5>
          <div class="followup-search-wrapper">
            <i class="fas fa-search followup-search-icon"></i>
            <input type="text" class="followup-search-input" id="followupPageSearch" placeholder="ค้นหาเพจ/บอท...">
          </div>
        </div>
        <div class="followup-page-list" id="followupPageSelector">
          <div class="followup-empty-state-small">
            <div class="text-muted small">กำลังโหลด...</div>
          </div>
        </div>
      </aside>

      <!-- Right Main Content -->
      <main class="followup-main">
        <!-- Empty State -->
        <div class="followup-empty-main" id="followupEmptyMain">
          <div class="app-empty">
            <div class="app-empty__icon"><i class="fas fa-layer-group"></i></div>
            <div class="app-empty__title">เลือกเพจ/บอทเพื่อตั้งค่า</div>
            <div class="app-empty__desc">เลือกจากรายการด้านซ้ายเพื่อจัดการข้อความติดตามและการตั้งค่า</div>
          </div>
        </div>

        <!-- Editor -->
        <div class="followup-editor" id="followupEditor">
          <div class="followup-editor-header">
            <div class="followup-editor-meta">
              <h4 class="followup-editor-name" id="editorPageName">—</h4>
              <span class="badge" id="editorPlatformBadge">LINE</span>
              <span class="followup-editor-status" id="editorAutoBadge">ปิดส่งอัตโนมัติ</span>
            </div>
            <div class="followup-editor-actions">
              <button class="followup-btn followup-btn-secondary" id="followupResetBtn" disabled>
                <i class="fas fa-undo"></i> คืนค่าเริ่มต้น
              </button>
              <button class="followup-btn followup-btn-primary" id="followupSaveBtn">
                <i class="fas fa-save"></i> บันทึก
              </button>
            </div>
          </div>

          <div class="followup-editor-tabs">
            <button class="followup-tab active" data-tab="general">
              <i class="fas fa-cog me-1"></i> ทั่วไป
            </button>
            <button class="followup-tab" data-tab="messages">
              <i class="fas fa-comment-dots me-1"></i> ข้อความติดตาม
            </button>
            <button class="followup-tab" data-tab="images">
              <i class="fas fa-images me-1"></i> คลังรูปภาพ
            </button>
          </div>

          <div class="followup-editor-body">
            <!-- Tab: General -->
            <div class="followup-tab-content active" data-tab="general">
              <div class="followup-settings-section">
                <div class="settings-group">
                  <div class="settings-label">สถานะระบบ</div>
                  <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" id="settingAutoSend" style="width: 2.8em; height: 1.4em;">
                    <label class="form-check-label fw-semibold ms-2" for="settingAutoSend">เปิดส่งข้อความติดตามอัตโนมัติ</label>
                  </div>
                  <div class="settings-hint">เมื่อเปิด ระบบจะส่งข้อความติดตามตามเวลาที่กำหนดโดยอัตโนมัติ</div>
                </div>

                <div class="settings-group d-none" id="emergencyStopGroup">
                  <div class="alert alert-danger d-flex align-items-start gap-2 mb-0">
                    <i class="fas fa-exclamation-triangle mt-1"></i>
                    <div>
                      <div class="fw-bold">Emergency Stop กำลังทำงาน</div>
                      <div class="small">ระบบติดตามถูกหยุดชั่วคราว ต้องปิด Emergency Stop ก่อนจึงจะเปิดส่งอัตโนมัติได้</div>
                    </div>
                  </div>
                </div>

                <div class="settings-group">
                  <div class="settings-label">การแสดงผล</div>
                  <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" id="settingShowChat" style="width: 2.8em; height: 1.4em;">
                    <label class="form-check-label fw-semibold ms-2" for="settingShowChat">แสดงป้ายสถานะในหน้าแชท</label>
                  </div>
                  <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="settingShowDashboard" style="width: 2.8em; height: 1.4em;">
                    <label class="form-check-label fw-semibold ms-2" for="settingShowDashboard">แสดงในแดชบอร์ด</label>
                  </div>
                </div>

              </div>
            </div>

            <!-- Tab: Messages -->
            <div class="followup-tab-content" data-tab="messages">
              <div class="followup-messages-layout">
                <!-- Editor Column -->
                <div class="followup-messages-editor">
                  <div class="d-flex align-items-center justify-content-between mb-3">
                    <div>
                      <div class="settings-label mb-1">ลำดับข้อความติดตาม</div>
                      <div class="settings-hint">ระบบจะเรียงลำดับตามเวลาอัตโนมัติ นับจากข้อความล่าสุดของลูกค้า</div>
                    </div>
                    <button class="followup-btn followup-btn-primary" id="btnAddRound">
                      <i class="fas fa-plus"></i> เพิ่มรอบ
                    </button>
                  </div>
                  <div class="followup-rounds-container" id="roundsContainer">
                    <div class="app-empty">
                      <div class="app-empty__desc">ยังไม่มีรอบการติดตาม กดปุ่ม "เพิ่มรอบ" เพื่อเริ่มต้น</div>
                    </div>
                  </div>
                </div>

                <!-- Preview Column -->
                <div class="followup-preview-panel" id="followupPreviewPanel">
                  <div class="followup-preview-header">
                    <i class="fas fa-eye me-1"></i> ตัวอย่างที่ลูกค้าจะได้รับ
                  </div>
                  <div class="followup-preview-body" id="followupPreviewBody">
                    <div class="followup-preview-empty">เลือกเพจและเพิ่มรอบการติดตามเพื่อดูตัวอย่าง</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Tab: Images -->
            <div class="followup-tab-content" data-tab="images">
              <div class="followup-settings-section">
                <div class="d-flex align-items-center justify-content-between mb-3">
                  <div>
                    <div class="settings-label mb-1">คลังรูปภาพ</div>
                    <div class="settings-hint">รูปภาพที่อัปโหลดไว้สำหรับใช้ในข้อความติดตาม</div>
                  </div>
                  <button class="followup-btn followup-btn-primary" id="btnUploadImage">
                    <i class="fas fa-upload"></i> อัปโหลดรูปภาพ
                  </button>
                </div>
                <div class="followup-image-grid" id="imageLibraryGrid">
                  <div class="app-empty">
                    <div class="app-empty__desc">ยังไม่มีรูปภาพในระบบ</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="alertToastContainer" class="alert-toast-container"></div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/followup-dashboard.js"></script>
</body>

</html>
