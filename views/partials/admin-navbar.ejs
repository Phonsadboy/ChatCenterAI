<%
  const current = typeof activePage !== 'undefined' ? activePage : '';
  const signedInUser = typeof adminUser !== 'undefined' && adminUser ? adminUser : null;
  const roleBadgeLabel = signedInUser ? (signedInUser.role === 'superadmin' ? 'แอดมินใหญ่' : 'ผู้ดูแลระบบ') : '';

  const pageTitles = {
    dashboard: 'แดชบอร์ด',
    categories: 'จัดการข้อมูล',
    settings: 'ตั้งค่า',
    settings2: 'ตั้งค่า',
    'agent-forge': 'ระบบโรงหลอมเอเจนต์',
    'agent-forge-run': 'รันโรงหลอมเอเจนต์',
    'instruction-ai': 'InstructionAI',
    'instruction-chat': 'Instruction Chat',
    'api-usage': 'สถิติ API',
    chat: 'แชท',
    orders: 'ออเดอร์',
    followup: 'ติดตามลูกค้า',
    broadcast: 'บรอดแคสต์',
    'facebook-posts': 'โพสต์ FB / คอมเมนต์',
    'facebook-comment': 'คอมเมนต์ Facebook',
    'customer-stats': 'สถิติลูกค้า',
  };
  const pageTitle = pageTitles[current] || 'จัดการ AI';

  const navGroups = [
    {
      title: 'AI & ระบบ',
      items: [
        { page: 'dashboard', label: 'แดชบอร์ด', icon: 'fa-tachometer-alt', href: '/admin/dashboard' },
        { page: 'categories', label: 'จัดการข้อมูล', icon: 'fa-database', href: '/admin/categories' },
        { page: 'settings2', label: 'ตั้งค่า', icon: 'fa-cogs', href: '/admin/settings2' },
        { page: 'agent-forge', label: 'โรงหลอมเอเจนต์', icon: 'fa-industry', href: '/admin/agent-forge' },
        { page: 'instruction-ai', label: 'InstructionAI', icon: 'fa-wand-magic-sparkles', href: '/admin/instruction-ai' },
        { page: 'api-usage', label: 'สถิติ API', icon: 'fa-chart-line', href: '/admin/api-usage' },
      ],
    },
    {
      title: 'ลูกค้า',
      items: [
        { page: 'chat', label: 'แชท', icon: 'fa-comments', href: '/admin/chat', badgeId: 'chatNotificationBadge' },
        { page: 'orders', label: 'ออเดอร์', icon: 'fa-shopping-basket', href: '/admin/orders' },
        { page: 'followup', label: 'ติดตามลูกค้า', icon: 'fa-user-clock', href: '/admin/followup' },
        { page: 'broadcast', label: 'บรอดแคสต์', icon: 'fa-bullhorn', href: '/admin/broadcast' },
        { page: 'facebook-posts', label: 'FB โพสต์/คอมเมนต์', icon: 'fa-comment-dots', href: '/admin/facebook-posts' },
        { page: 'customer-stats', label: 'สถิติลูกค้า', icon: 'fa-chart-bar', href: '/admin/customer-stats' },
      ],
    },
  ];

  const isActive = (page) => {
    if (!current || !page) return false;
    if (page === 'settings2') return current === 'settings' || current === 'settings2';
    if (page === 'instruction-ai') return current === 'instruction-ai' || current === 'instruction-chat';
    return current === page;
  };

  // Mobile bottom nav primary items (max 4 + more)
  const mobilePrimary = [
    { page: 'dashboard', label: 'แดชบอร์ด', icon: 'fa-tachometer-alt', href: '/admin/dashboard' },
    { page: 'chat', label: 'แชท', icon: 'fa-comments', href: '/admin/chat', badgeId: 'chatNotificationBadge' },
    { page: 'orders', label: 'ออเดอร์', icon: 'fa-shopping-basket', href: '/admin/orders' },
    { page: 'settings2', label: 'ตั้งค่า', icon: 'fa-cogs', href: '/admin/settings2' },
  ];
%>

<!-- Layout CSS/JS -->
<link href="/css/admin-layout.css" rel="stylesheet">
<script>
  /* FOUC prevention: add layout class immediately before first paint */
  (function () {
    var b = document.body;
    if (b) b.classList.add('has-admin-layout');
  })();
  window.__adminActivePage = '<%= current %>';
  window.adminAuth = window.adminAuth || {};
  window.adminAuth.requirePasscode = <%= typeof isPasscodeRequired !== 'undefined' ? (isPasscodeRequired ? 'true' : 'false') : 'false' %>;
  window.adminAuth.user = <%- JSON.stringify(signedInUser || null).replace(/</g, '\\u003c') %>;
</script>
<script src="/js/admin-layout.js" defer></script>

<!-- ======================== Top Bar ======================== -->
<header class="app-topbar" id="appTopbar">
  <div class="app-topbar__left">
    <!-- Desktop sidebar toggle -->
    <button class="app-topbar__toggle d-none d-lg-inline-flex" data-layout-toggle="desktop" data-desktop-toggle aria-label="พับ/ขยายเมนูด้านข้าง">
      <i class="fas fa-bars"></i>
    </button>
    <!-- Mobile sidebar toggle -->
    <button class="app-topbar__toggle d-lg-none d-inline-flex" data-layout-toggle="mobile" data-mobile-toggle aria-label="เปิดเมนูด้านข้าง">
      <i class="fas fa-bars"></i>
    </button>
    <a class="app-topbar__brand d-none d-sm-flex" href="/admin/dashboard">
      <i class="fas fa-robot"></i>
      <span>จัดการ AI</span>
    </a>
    <span class="app-topbar__title"><%= pageTitle %></span>
  </div>

  <div class="app-topbar__spacer"></div>

  <div class="app-topbar__right">
    <select id="globalFontSelector" class="app-topbar__font d-none d-lg-block">
      <option value="'Mali', 'Inter', sans-serif">Mali</option>
      <option value="'Sarabun', sans-serif">Sarabun</option>
      <option value="'Krub', sans-serif">Krub</option>
      <option value="'Mitr', sans-serif">Mitr</option>
      <option value="'Pridi', serif">Pridi</option>
      <option value="'Niramit', sans-serif">Niramit</option>
    </select>

    <% if (signedInUser) { %>
      <span class="app-topbar__role">
        <i class="fas fa-user-shield"></i>
        <%= roleBadgeLabel %>
        <% if (signedInUser.label) { %>
          <span class="text-muted">&middot; <%= signedInUser.label %></span>
        <% } %>
      </span>
      <button class="app-topbar__logout" id="adminLogoutBtn" title="ออกจากระบบ" aria-label="ออกจากระบบ">
        <i class="fas fa-sign-out-alt"></i>
      </button>
    <% } %>
  </div>
</header>

<!-- ======================== Sidebar (Desktop) ======================== -->
<aside class="app-sidebar" id="appSidebar">
  <div class="app-sidebar__scroll">
    <% navGroups.forEach((group, gIdx) => { %>
      <div class="app-sidebar__section-title"><%= group.title %></div>
      <nav class="app-sidebar__nav" aria-label="<%= group.title %>">
        <% group.items.forEach((item) => { %>
          <a
            href="<%= item.href %>"
            class="app-sidebar__item <%= isActive(item.page) ? 'is-active' : '' %>"
            data-page="<%= item.page %>"
          >
            <i class="fas <%= item.icon %>"></i>
            <span class="app-sidebar__text"><%= item.label %></span>
            <% if (item.badgeId) { %>
              <span class="app-sidebar__badge" id="<%= item.badgeId %>" data-chat-badge style="display:none">0</span>
            <% } %>
          </a>
        <% }) %>
      </nav>
    <% }) %>
  </div>

  <div class="app-sidebar__footer">
    <a class="app-sidebar__back" href="/admin/dashboard">
      <i class="fas fa-arrow-left"></i>
      <span>กลับหน้าแดชบอร์ด</span>
    </a>
  </div>
</aside>

<!-- ======================== Mobile Bottom Nav ======================== -->
<nav class="app-mobile-nav" id="appMobileNav" aria-label="เมนูหลัก">
  <div class="app-mobile-nav__inner">
    <% mobilePrimary.forEach((item, idx) => { %>
      <% if (idx > 0) { %>
        <div class="app-mobile-nav__divider" aria-hidden="true"></div>
      <% } %>
      <a
        href="<%= item.href %>"
        class="app-mobile-nav__item <%= isActive(item.page) ? 'is-active' : '' %>"
        data-page="<%= item.page %>"
      >
        <i class="fas <%= item.icon %>"></i>
        <span class="app-mobile-nav__label"><%= item.label %></span>
        <% if (item.badgeId) { %>
          <span class="app-mobile-nav__badge" data-chat-badge style="display:none">0</span>
        <% } %>
      </a>
    <% }) %>

    <div class="app-mobile-nav__divider" aria-hidden="true"></div>

    <button class="app-mobile-nav__item" id="appMobileNavMore" type="button" aria-label="เมนูอื่น ๆ">
      <i class="fas fa-ellipsis-h"></i>
      <span class="app-mobile-nav__label">อื่น ๆ</span>
    </button>
  </div>
</nav>

<!-- Mobile More Sheet -->
<div class="app-mobile-nav__more-sheet" id="appMobileNavMoreSheet" aria-hidden="true">
  <div class="app-mobile-nav__more-backdrop"></div>
  <div class="app-mobile-nav__more-panel">
    <div class="app-mobile-nav__more-handle" aria-hidden="true"></div>
    <% navGroups.forEach((group) => { %>
      <div class="app-mobile-nav__more-title"><%= group.title %></div>
      <div class="app-mobile-nav__more-grid">
        <% group.items.forEach((item) => { %>
          <a
            href="<%= item.href %>"
            class="app-mobile-nav__more-item <%= isActive(item.page) ? 'is-active' : '' %>"
            data-page="<%= item.page %>"
          >
            <i class="fas <%= item.icon %>"></i>
            <span><%= item.label %></span>
          </a>
        <% }) %>
      </div>
    <% }) %>
  </div>
</div>

<!-- ======================== Overlay ======================== -->
<div class="app-sidebar-overlay" id="appSidebarOverlay"></div>
